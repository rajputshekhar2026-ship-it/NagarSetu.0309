{
  "name": "nagarsetu-admin-dashboard",
  "version": "2.0.0",
  "description": "NagarSetu Municipal Command Center — Production Grade",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "nodemon server/index.js",
    "build:cpp": "g++ -O2 -o cpp/risk_calc cpp/risk_calculator.cpp -lm && echo '✅ C++ risk engine compiled'",
    "test:ai": "python3 python/ai_verifier.py '{\"type\":\"HARASSMENT\",\"description\":\"Suspicious person near school\",\"severity\":4,\"timestamp\":0,\"status\":\"pending\"}'",
    "setup": "npm install && npm run build:cpp && echo '✅ NagarSetu Admin ready'"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.106.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "socket.io": "^4.7.2",
    "uuid": "^9.0.0",
    "winston": "^3.11.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
